{
  "meta": {
    "id": "ui-inventory-legacy",
    "lang": "ja",
    "version": "0.1.0"
  },
  "rules": {
    "protectColorTags": true,
    "protectHtmlEntities": true
  },
  "entries": [
    {
      "key": "to exit",
      "context": "XRL.UI.InventoryScreen",
      "text": "で終了"
    },
    {
      "key": "to scroll up",
      "context": "XRL.UI.InventoryScreen",
      "text": "で上にスクロール"
    },
    {
      "key": "to scroll down",
      "context": "XRL.UI.InventoryScreen",
      "text": "で下にスクロール"
    },
    {
      "key": "[{{W|?}} view quick keys]",
      "context": "XRL.UI.InventoryScreen",
      "text": "[{{W|?}} クイックキー一覧]"
    },
    {
      "key": "<more...>",
      "context": "XRL.UI.InventoryScreen",
      "text": "<続き...>"
    },
    {
      "key": "<...more>",
      "context": "XRL.UI.InventoryScreen",
      "text": "<...続き>"
    },
    {
      "key": "{count} items hidden by filter",
      "context": "XRL.UI.InventoryScreen",
      "text": "フィルターで非表示: {count}"
    }
  ]
}
